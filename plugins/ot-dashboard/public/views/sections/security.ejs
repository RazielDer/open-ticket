<% const values = securityWorkspace.values %>

<% if (securityWorkspace.warnings.length) { %>
  <div class="entry-stack" style="margin-bottom:16px">
    <% securityWorkspace.warnings.forEach((warning) => { %>
      <div class="inline-alert <%= warning.tone %>"><%= warning.message %></div>
    <% }) %>
  </div>
<% } %>

<form method="post" action="<%= securityWorkspace.formAction %>" class="entry-stack">
  <input type="hidden" name="csrfToken" value="<%= csrfToken %>">

  <section class="section-card">
    <div class="section-heading">
      <h3><%= t("security.sections.routing.title") %></h3>
    </div>
    <p class="item-copy"><%= t("security.sections.routing.description") %></p>
    <div class="form-grid">
      <label>
        <span class="field-label"><%= t("security.fields.publicBaseUrl") %></span>
        <input class="text-input" type="url" name="publicBaseUrl" value="<%= values.publicBaseUrl %>" placeholder="https://dashboard.example">
      </label>
      <label>
        <span class="field-label"><%= t("security.fields.viewerPublicBaseUrl") %></span>
        <input class="text-input" type="url" name="viewerPublicBaseUrl" value="<%= values.viewerPublicBaseUrl %>" placeholder="https://records.example">
      </label>
      <label>
        <span class="field-label"><%= t("security.fields.trustProxyHops") %></span>
        <input class="text-input" type="number" min="0" step="1" name="trustProxyHops" value="<%= values.trustProxyHops %>">
      </label>
    </div>
  </section>

  <section class="section-card">
    <div class="section-heading">
      <h3><%= t("security.sections.rbac.title") %></h3>
    </div>
    <p class="item-copy"><%= t("security.sections.rbac.description") %></p>
    <div class="form-grid two-up">
      <label>
        <span class="field-label"><%= t("security.fields.ownerUserIds") %></span>
        <textarea class="text-input" name="rbac.ownerUserIds" rows="4"><%= values.ownerUserIds %></textarea>
      </label>
      <label>
        <span class="field-label"><%= t("security.fields.reviewerRoleIds") %></span>
        <textarea class="text-input" name="rbac.roleIds.reviewer" rows="4"><%= values.reviewerRoleIds %></textarea>
      </label>
      <label>
        <span class="field-label"><%= t("security.fields.editorRoleIds") %></span>
        <textarea class="text-input" name="rbac.roleIds.editor" rows="4"><%= values.editorRoleIds %></textarea>
      </label>
      <label>
        <span class="field-label"><%= t("security.fields.adminRoleIds") %></span>
        <textarea class="text-input" name="rbac.roleIds.admin" rows="4"><%= values.adminRoleIds %></textarea>
      </label>
      <label>
        <span class="field-label"><%= t("security.fields.reviewerUserIds") %></span>
        <textarea class="text-input" name="rbac.userIds.reviewer" rows="4"><%= values.reviewerUserIds %></textarea>
      </label>
      <label>
        <span class="field-label"><%= t("security.fields.editorUserIds") %></span>
        <textarea class="text-input" name="rbac.userIds.editor" rows="4"><%= values.editorUserIds %></textarea>
      </label>
      <label>
        <span class="field-label"><%= t("security.fields.adminUserIds") %></span>
        <textarea class="text-input" name="rbac.userIds.admin" rows="4"><%= values.adminUserIds %></textarea>
      </label>
    </div>
    <p class="field-help"><%= t("security.fields.listHelp") %></p>
  </section>

  <section class="section-card">
    <div class="section-heading">
      <h3><%= t("security.sections.breakglass.title") %></h3>
    </div>
    <p class="item-copy"><%= t("security.sections.breakglass.description") %></p>
    <label class="checkbox-row">
      <input type="checkbox" name="auth.breakglass.enabled" value="true" <%= values.breakglassEnabled ? 'checked' : '' %>>
      <span><%= t("security.fields.breakglassEnabled") %></span>
    </label>
    <p class="field-help"><%= t("security.sections.breakglass.help") %></p>
  </section>

  <section class="section-card">
    <div class="section-heading">
      <h3><%= t("security.sections.secrets.title") %></h3>
    </div>
    <p class="item-copy"><%= t("security.sections.secrets.description") %></p>
    <div class="card-grid">
      <% securityWorkspace.secrets.forEach((secret) => { %>
        <article class="item-card">
          <div class="item-card-header">
            <h3><%= secret.title %></h3>
            <span class="status-pill tone-<%= secret.tone %>"><%= secret.label %></span>
          </div>
          <p class="item-copy"><%= secret.detail %></p>
        </article>
      <% }) %>
    </div>
  </section>

  <div class="section-card editor-savebar">
    <div class="editor-savebar-copy">
      <strong><%= t("security.savebar.title") %></strong>
      <p class="field-help"><%= t("security.savebar.body") %></p>
    </div>
    <div class="card-actions">
      <button class="btn primary" type="submit"><%= t("common.save") %></button>
    </div>
  </div>
</form>
