<section class="section-card plugin-library-shell">
  <div class="plugin-library-header">
    <div class="plugin-library-copy">
      <h2 class="plugin-library-title"><%= t("addOns.inventoryTitle") %></h2>
      <p class="item-copy"><%= t("addOns.inventoryBody", { count: plugins.length }) %></p>
    </div>
    <div class="plugin-library-toolbar">
      <div class="plugin-library-search">
        <label class="sr-only" for="pluginSearch"><%= t("addOns.searchLabel") %></label>
        <input
          id="pluginSearch"
          class="text-input"
          type="search"
          placeholder="<%= t('addOns.searchPlaceholder') %>"
          data-filter-input="#pluginInventoryGroups"
          data-filter-empty="#pluginInventoryEmpty"
        >
      </div>
    </div>
  </div>

  <% const inventoryGroups = Array.isArray(locals.pluginGroups) ? locals.pluginGroups : [] %>

  <% if (plugins.length) { %>
    <div id="pluginInventoryGroups" class="plugin-library-groups">
      <% inventoryGroups.forEach((group) => { %>
        <section class="plugin-library-group" data-filter-group data-group-id="<%= group.id %>">
          <div class="section-heading plugin-library-group-heading">
            <div class="plugin-library-group-copy">
              <h3 class="plugin-library-group-title"><%= group.title %></h3>
            </div>
            <span class="plugin-library-group-count"><%= group.countLabel %></span>
          </div>
          <div class="plugin-library-group-frame">
            <% group.items.forEach((plugin) => { %>
              <article
                class="plugin-library-row"
                data-plugin-group="<%= plugin.groupId %>"
                data-filter-item="<%= plugin.searchText %>"
              >
                <div class="plugin-library-item-main">
                  <p class="config-file plugin-library-item-id"><%= plugin.id %></p>
                  <div class="plugin-library-card-title">
                    <h3><%= plugin.name || plugin.id %></h3>
                    <p class="item-copy plugin-library-meta">
                      <span><%= t("addOns.byAuthor", { authors: plugin.authorsLabel }) %></span>
                      <span class="plugin-library-meta-divider" aria-hidden="true">/</span>
                      <span><%= plugin.assetCount === 1 ? t("addOns.jsonCountSingle") : plugin.assetCount > 1 ? t("addOns.jsonCountPlural", { count: plugin.assetCount }) : t("addOns.jsonCountNone") %></span>
                    </p>
                  </div>
                  <p class="item-copy plugin-library-description"><%= plugin.shortDescription || t("addOns.emptyBody") %></p>
                </div>
                <div class="plugin-library-actions">
                  <a class="plugin-library-action-link" href="<%= plugin.detailHref %>"><%= t("addOns.openAction") %></a>
                  <span class="plugin-library-action-divider" aria-hidden="true">/</span>
                  <a class="plugin-library-action-link subtle" href="<%= plugin.manifestExportHref %>"><%= t("addOns.manifestAction") %></a>
                </div>
              </article>
            <% }) %>
          </div>
        </section>
      <% }) %>
    </div>
    <div id="pluginInventoryEmpty" class="empty-panel plugin-filter-empty" hidden>
      <h3><%= t("addOns.filteredEmptyTitle") %></h3>
      <p><%= t("addOns.filteredEmptyBody") %></p>
    </div>
  <% } else { %>
    <div class="empty-panel">
      <h3><%= t("addOns.emptyTitle") %></h3>
      <p><%= t("addOns.emptyBody") %></p>
    </div>
  <% } %>
</section>
