<section class="section-card">
  <div class="section-heading">
    <h3><%= advancedModel.sections.security.title %></h3>
  </div>
  <p class="item-copy"><%= advancedModel.sections.security.description %></p>
  <div class="card-grid">
    <% advancedModel.sections.security.links.forEach((link) => { %>
      <article class="item-card">
        <h3><%= link.label %></h3>
        <p class="item-copy"><%= advancedModel.sections.security.description %></p>
        <div class="card-actions">
          <a class="btn secondary" href="<%= link.href %>"><%= link.label %></a>
        </div>
      </article>
    <% }) %>
  </div>
</section>

