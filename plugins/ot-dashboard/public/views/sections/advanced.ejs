        <div class="card-actions">
          <a class="btn subtle" href="<%= link.href %>" <% if (link.target) { %>target="<%= link.target %>"<% } %> <% if (link.rel) { %>rel="<%= link.rel %>"<% } %>><%= link.label %></a>
