<section class="section-card">
  <div class="section-heading">
    <h3><%= t("backupsPage.inventoryTitle") %></h3>
  </div>
  <p class="item-copy"><%= t("backupsPage.inventoryBody") %></p>
  <% if (backups.length) { %>
    <div class="table-wrap">
      <table class="data-table">
        <thead>
          <tr>
            <th><%= t("backupsPage.table.id") %></th>
            <th><%= t("backupsPage.table.created") %></th>
            <th><%= t("backupsPage.table.source") %></th>
            <th><%= t("backupsPage.table.configs") %></th>
          </tr>
        </thead>
        <tbody>
          <% backups.forEach((backup) => { %>
            <tr>
              <td><%= backup.id %></td>
              <td><%= backup.createdAt %></td>
              <td><%= backup.source %></td>
              <td><%= backup.configs.length %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } else { %>
    <div class="empty-panel">
      <h3><%= t("backupsPage.inventoryEmptyTitle") %></h3>
      <p><%= t("backupsPage.inventoryEmptyBody") %></p>
    </div>
  <% } %>
</section>

<% if (restorePreview) { %>
  <section class="section-card">
    <div class="section-heading">
      <h3><%= t("backupsPage.restoreTitle") %></h3>
    </div>
    <p class="item-copy"><%= t("backupsPage.restoreBody", { backupId: restorePreview.backup.id, fileName: restorePreview.definition.fileName }) %></p>
    <div class="sticky-actions">
      <a class="btn primary" href="<%= restorePreview.restoreHref %>"><%= t("backupsPage.restoreAction") %></a>
    </div>
  </section>
<% } %>

<section class="section-card">
  <div class="section-heading">
    <h3><%= t("backupsPage.verificationTitle") %></h3>
  </div>
  <div class="list-grid">
    <article class="item-card">
      <h3><%= t("backupsPage.verificationNoteTitle") %></h3>
      <p class="item-copy"><%= t("backupsPage.verificationNoteBody", { state: verification.exists ? t("backupsPage.verificationPresent") : t("backupsPage.verificationMissing"), path: verification.verificationPath }) %></p>
      <p class="item-copy"><%= t("backupsPage.verificationLastUpdate", { updatedAt: verification.updatedAt }) %></p>
    </article>
    <article class="item-card">
      <h3><%= t("backupsPage.verificationCommandsTitle") %></h3>
      <div class="subsection-stack">
        <% verification.commands.forEach((command) => { %>
          <article class="subsection-card">
            <code><%= command %></code>
          </article>
        <% }) %>
      </div>
    </article>
  </div>
</section>
