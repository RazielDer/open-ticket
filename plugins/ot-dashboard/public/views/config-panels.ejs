<!DOCTYPE html>
<html lang="<%= locale %>">
<head>
  <%- include('partials/head', { pageTitle }) %>
</head>
<body class="dashboard-body" data-base-path="<%= basePath %>" data-csrf-token="<%= csrfToken %>" style="--brand-primary:<%= brand.primaryColor %>;--brand-accent:<%= brand.accentColor %>;--brand-background:<%= brand.backgroundColor %>;--brand-surface:<%= brand.surfaceColor %>;--brand-text:<%= brand.textColor %>;">
  <div class="app-shell">
    <%- include('partials/header', {
      headerClass: 'editor-workspace-header-no-logo',
      headerShowLogo: false,
      headerActions: dashboardAccess?.tier === 'admin'
        ? [{ href: assetPath('admin'), label: t('common.admin'), variant: 'secondary' }]
        : [],
      logoutAction: assetPath('logout')
    }) %>

    <main class="page-wrap editor-workspace-page editor-workspace-panels-page">
      <% if (saved) { %>
        <div class="inline-alert success"><%= t("common.statusSaved") %></div>
      <% } %>

      <%- include('partials/editor-workspace-header', {
        eyebrow: '',
        title: t('panels.title'),
        subtitle: t('panels.subtitle'),
        actions: [],
        stats: [
          { label: t('common.file'), value: advancedTools.fileName },
          { label: t('panels.workspace.savedPanelsLabel'), value: String(panels.length) }
        ]
      }) %>

      <div class="editor-workspace-grid">
        <aside class="editor-workspace-sidebar">
          <section class="section-card panels-inventory-shell">
            <div class="section-heading panels-inventory-heading">
              <div>
                <h3><%= t("panels.workspace.inventoryTitle") %></h3>
              </div>
              <div class="card-actions">
                <button class="btn primary" type="button" id="createPanelButton"><%= t("panels.workspace.newButton") %></button>
              </div>
            </div>
            <div class="editor-outline-list panels-inventory-list" id="panelInventory">
              <% if (panels.length) { %>
                <% panels.forEach((panel, index) => { %>
                  <button class="editor-outline-link panels-inventory-item" type="button" data-panel-select data-index="<%= index %>">
                    <span class="panels-inventory-copy">
                      <strong><%= panel.name %></strong>
                      <span class="config-file"><%= panel.dropdown ? t("panels.workspace.dropdownMode") : t("panels.workspace.buttonsMode") %></span>
                    </span>
                    <span class="config-file panels-inventory-id"><%= panel.id %></span>
                  </button>
                <% }) %>
              <% } else { %>
                <div class="empty-panel editor-sidebar-empty">
                  <h3><%= t("panels.emptyTitle") %></h3>
                  <p><%= t("panels.emptyBody") %></p>
                </div>
              <% } %>
            </div>
          </section>

          <%- include('partials/editor-advanced-tools', { advancedTools }) %>
        </aside>

        <div class="editor-workspace-main">
          <form id="panelForm" class="editor-workspace-stage panels-workspace-main">
            <input type="hidden" id="panelEditIndex" value="-1">

            <section class="section-card panels-stage-shell">
              <div class="section-heading editor-toolbar">
                <div>
                  <h3 id="panelWorkspaceTitle"><%= t("panels.workspace.newDraftTitle") %></h3>
                </div>
                <div class="card-actions editor-toolbar-actions">
                  <button class="btn secondary" type="button" id="duplicatePanelButton"><%= t("panels.workspace.duplicateButton") %></button>
                  <button class="btn subtle" type="button" id="movePanelUpButton"><%= t("panels.workspace.moveUp") %></button>
                  <button class="btn subtle" type="button" id="movePanelDownButton"><%= t("panels.workspace.moveDown") %></button>
                  <button class="btn subtle" type="button" id="deletePanelButton"><%= t("common.delete") %></button>
                </div>
              </div>

              <div class="summary-grid panels-summary-grid">
                <article class="summary-card">
                  <span class="summary-label"><%= t("panels.workspace.positionLabel") %></span>
                  <strong class="summary-value" id="panelOrderPosition"><%= t("panels.workspace.unsavedPosition") %></strong>
                </article>
                <article class="summary-card">
                  <span class="summary-label"><%= t("panels.workspace.modeLabel") %></span>
                  <strong class="summary-value" id="panelDisplayMode" data-buttons-label="<%= t('panels.workspace.buttonsMode') %>" data-dropdown-label="<%= t('panels.workspace.dropdownMode') %>"><%= t("panels.workspace.buttonsMode") %></strong>
                </article>
                <article class="summary-card">
                  <span class="summary-label"><%= t("panels.workspace.optionCountLabel") %></span>
                  <strong class="summary-value" id="selectedOptionCount">0</strong>
                </article>
              </div>
            </section>

            <div class="panels-two-column-grid panels-primary-grid">
              <section class="section-card panels-identity-card">
                <div class="section-heading">
                  <h3><%= t("panels.workspace.identityTitle") %></h3>
                </div>
                <div class="form-grid two-up">
                  <label>
                    <span class="field-label"><%= t("panels.fields.id") %></span>
                    <input class="text-input" id="panelId" type="text">
                  </label>
                  <label>
                    <span class="field-label"><%= t("panels.fields.name") %></span>
                    <input class="text-input" id="panelName" type="text">
                  </label>
                  <label class="checkbox-field">
                    <input type="checkbox" id="panelDropdown">
                    <span><%= t("panels.fields.useDropdown") %></span>
                  </label>
                  <label>
                    <span class="field-label"><%= t("panels.fields.dropdownPlaceholder") %></span>
                    <input class="text-input" id="dropdownPlaceholder" type="text">
                  </label>
                  <label class="span-2">
                    <span class="field-label"><%= t("panels.fields.text") %></span>
                    <textarea class="code-area compact" id="panelText"></textarea>
                  </label>
                </div>
              </section>

              <section class="section-card panels-embed-card">
                <div class="section-heading">
                  <h3><%= t("panels.sections.embed") %></h3>
                </div>
                <div class="form-grid two-up">
                  <label class="checkbox-field">
                    <input type="checkbox" id="embedEnabled">
                    <span><%= t("panels.fields.embedEnabled") %></span>
                  </label>
                  <label>
                    <span class="field-label"><%= t("panels.fields.embedTitle") %></span>
                    <input class="text-input" id="embedTitle" type="text">
                  </label>
                  <label class="span-2">
                    <span class="field-label"><%= t("panels.fields.embedDescription") %></span>
                    <textarea class="code-area compact" id="embedDescription"></textarea>
                  </label>
                  <label>
                    <span class="field-label"><%= t("panels.fields.embedColor") %></span>
                    <input class="text-input color-input" id="embedColor" type="color" value="#000000">
                  </label>
                </div>
              </section>
            </div>

            <div class="panels-two-column-grid panels-builder-grid">
              <section class="section-card panels-picker-card">
                <div class="section-heading">
                  <h3><%= t("panels.workspace.pickerTitle") %></h3>
                </div>
                <div class="inline-alert warning" id="dropdownCompatibilityWarning" hidden>
                  <strong><%= t("panels.workspace.dropdownWarningTitle") %></strong>
                  <p><%= t("panels.flash.validationDropdownOptions") %></p>
                </div>
                <% if (availableOptions.length) { %>
                  <div class="checkbox-grid" id="panelOptionPicker">
                    <% availableOptions.forEach((option) => { %>
                      <label class="checkbox-field">
                        <input type="checkbox" data-option-id="<%= option.id %>">
                        <span>
                          <strong><%= option.emoji || '' %> <%= option.name %></strong>
                          <span class="config-file"><%= option.id %> · <%= option.type %></span>
                          <span class="field-help"><%= option.description || t("options.labels.noDescription") %></span>
                        </span>
                      </label>
                    <% }) %>
                  </div>
                <% } else { %>
                  <div class="empty-panel">
                    <h3><%= t("panels.workspace.pickerEmptyTitle") %></h3>
                    <p><%= t("panels.workspace.pickerEmptyBody") %></p>
                  </div>
                <% } %>
              </section>

              <section class="section-card panels-preview-card">
                <div class="section-heading">
                  <h3><%= t("panels.workspace.previewTitle") %></h3>
                </div>
                <div class="panels-preview-grid">
                  <article class="panels-preview-panel">
                    <div class="panels-preview-panel-heading">
                      <h4><%= t("panels.workspace.selectedOptionsTitle") %></h4>
                      <span class="pill-tag" id="selectedOptionCountPill">0</span>
                    </div>
                    <p class="editor-intro" id="selectedOptionsEmpty"><%= t("panels.workspace.selectedOptionsEmpty") %></p>
                    <div class="pill-list panels-selected-options-list" id="selectedOptionsList"></div>
                  </article>

                  <article class="panels-preview-panel">
                    <h4><%= t("panels.workspace.memberPreviewTitle") %></h4>
                    <p class="item-copy" id="panelPreviewText" data-empty-label="<%= t('panels.labels.noPreview') %>"><%= t("panels.labels.noPreview") %></p>
                    <p class="editor-intro" id="panelPreviewEmbedSummary" data-empty-label="<%= t('panels.workspace.embedSummaryEmpty') %>"><%= t("panels.workspace.embedSummaryEmpty") %></p>
                    <p class="field-help" id="panelPreviewMeta" data-no-placeholder-label="<%= t('panels.workspace.noPlaceholder') %>" data-placeholder-label="<%= t('panels.workspace.placeholderLabel') %>"></p>
                  </article>
                </div>
              </section>
            </div>

            <details class="section-card editor-disclosure">
              <summary>
                <h3><%= t("editor.advancedTitle") %></h3>
              </summary>
              <div class="editor-disclosure-body">
                <section class="subsection-card">
                  <h4><%= t("panels.sections.embed") %></h4>
                  <div class="form-grid two-up">
                    <label>
                      <span class="field-label"><%= t("panels.fields.embedUrl") %></span>
                      <input class="text-input" id="embedUrl" type="url">
                    </label>
                    <label>
                      <span class="field-label"><%= t("panels.fields.imageUrl") %></span>
                      <input class="text-input" id="embedImage" type="url">
                    </label>
                    <label>
                      <span class="field-label"><%= t("panels.fields.thumbnailUrl") %></span>
                      <input class="text-input" id="embedThumbnail" type="url">
                    </label>
                    <label>
                      <span class="field-label"><%= t("panels.fields.footerText") %></span>
                      <input class="text-input" id="embedFooter" type="text">
                    </label>
                    <label class="checkbox-field">
                      <input type="checkbox" id="embedTimestamp">
                      <span><%= t("panels.fields.showTimestamp") %></span>
                    </label>
                  </div>
                </section>

                <section class="subsection-card">
                  <h4><%= t("panels.sections.settings") %></h4>
                  <div class="form-grid two-up">
                    <label>
                      <span class="field-label"><%= t("panels.fields.describeLayout") %></span>
                      <select class="select-input" id="describeLayout">
                        <% describeLayouts.forEach((value) => { %>
                          <option value="<%= value %>"><%= value %></option>
                        <% }) %>
                      </select>
                    </label>
                    <label>
                      <span class="field-label"><%= t("panels.fields.describeCustomTitle") %></span>
                      <input class="text-input" id="describeCustomTitle" type="text">
                    </label>
                    <label class="checkbox-field">
                      <input type="checkbox" id="maxTicketsText">
                      <span><%= t("panels.fields.maxTicketsText") %></span>
                    </label>
                    <label class="checkbox-field">
                      <input type="checkbox" id="maxTicketsEmbed">
                      <span><%= t("panels.fields.maxTicketsEmbed") %></span>
                    </label>
                    <label class="checkbox-field">
                      <input type="checkbox" id="describeInText">
                      <span><%= t("panels.fields.describeInText") %></span>
                    </label>
                    <label class="checkbox-field">
                      <input type="checkbox" id="describeInFields">
                      <span><%= t("panels.fields.describeInFields") %></span>
                    </label>
                    <label class="checkbox-field">
                      <input type="checkbox" id="describeInDescription">
                      <span><%= t("panels.fields.describeInDescription") %></span>
                    </label>
                  </div>
                </section>
              </div>
            </details>

            <div class="section-card editor-savebar panels-savebar">
              <div class="editor-savebar-copy">
                <h3><%= t("panels.workspace.saveTitle") %></h3>
              </div>
              <div class="card-actions sticky-actions editor-savebar-actions">
                <button class="btn primary" type="submit"><%= t("common.save") %></button>
              </div>
            </div>
          </form>
        </div>
      </div>

      <textarea id="panels-data" hidden><%= JSON.stringify(panels) %></textarea>
      <textarea id="available-options-data" hidden><%= JSON.stringify(availableOptions) %></textarea>
      <textarea id="dependency-graph-data" hidden><%= dependencyGraph %></textarea>
      <textarea id="page-messages" hidden><%= messages %></textarea>
      <textarea id="page-contracts" hidden><%= contracts %></textarea>
    </main>

    <%- include('partials/footer') %>
  </div>

  <script src="<%= assetPath('js/dashboard-ui.js') %>"></script>
  <script src="<%= assetPath('js/config-panels.js') %>"></script>
</body>
</html>
